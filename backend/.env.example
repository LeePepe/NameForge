# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: claude-code | anthropic-api | ollama | azure-foundry
# Defaults to "claude-code" (requires running inside a Claude Code session)
LLM_PROVIDER=claude-code

# ─── anthropic-api settings (LLM_PROVIDER=anthropic-api) ──────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override model (default: claude-opus-4-5)
# ANTHROPIC_MODEL=claude-opus-4-5

# ─── ollama settings (LLM_PROVIDER=ollama) ────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ─── azure-foundry settings (LLM_PROVIDER=azure-foundry) ─────────────────────
# Endpoint from your Azure AI Foundry / Cognitive Services account
# AZURE_FOUNDRY_ENDPOINT=https://<your-account>.cognitiveservices.azure.com/
# API key from: az cognitiveservices account keys list --name <account> --resource-group <rg>
# AZURE_FOUNDRY_API_KEY=your_azure_foundry_api_key_here
# Deployment name (must match a deployed model in your Foundry account)
# Available deployments: gpt-4.1-mini, gpt-4o, DeepSeek-R1-0528, Kimi-K2.5, ...
# AZURE_FOUNDRY_DEPLOYMENT=gpt-4.1-mini
# API version (default: 2024-12-01-preview)
# AZURE_FOUNDRY_API_VERSION=2024-12-01-preview
