{
  "version": 2,
  "buildCommand": "npm run build --workspace=frontend && npm run build --workspace=backend",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/index.ts"
    },
    {
      "source": "/health",
      "destination": "/backend/src/index.ts"
    }
  ]
}
